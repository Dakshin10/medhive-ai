# =============================================================
# MedHive AI — .gitignore
# =============================================================

# ─── Python ───────────────────────────────────────────────
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
*.so

# ─── Environment & Secrets ────────────────────────────────
.env
.env.*
!.env.example
*.secret
secrets.json

# ─── Database ─────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
medhive.db

# ─── Vector Store (ChromaDB) ──────────────────────────────
backend/chroma_db/

# ─── Uploads & Generated Output ───────────────────────────
backend/uploads/
backend/outputs/
test_doc/

# ─── Node.js / Next.js ────────────────────────────────────
node_modules/
.next/
out/
.turbo/
.vercel/
*.tsbuildinfo
next-env.d.ts

# ─── Package manager locks (keep one, ignore others) ──────
# Uncomment whichever you DON'T use:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ─── IDE & Editors ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# ─── Logs ─────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Testing ──────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/
.tox/

# ─── Type checking ────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# ─── Distribution / Packaging ─────────────────────────────
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# ─── Jupyter Notebooks ────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── macOS ────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─── Windows ──────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Temporary files ──────────────────────────────────────
*.tmp
*.temp
*.bak
*.backup
*.orig